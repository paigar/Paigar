---
layout: layouts/base.njk
---
<article class="prosa">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {% if tags %}
        <div class="postcard__tags">
          {%- for tag in tags | filterTagList %}
            <span class="tag">{{ tag }}</span>
          {%- endfor %}
        </div>
      {% endif %}
    </div>
  </header>

  {{ content | safe }}
</article>

{%- css %}
.post-header {
  margin-bottom: var(--space-xl);
}
.post-meta {
  font-family: var(--font-mono);
  font-size: var(--fs-1);
  color: var(--color-texto-alt);
  display: flex;
  align-items: center;
  gap: var(--space-m);
  flex-wrap: wrap;
  margin-top: var(--space-s);
}
{% endcss %}
