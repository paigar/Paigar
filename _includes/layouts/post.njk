---
layout: layouts/base.njk
---
<article class="prosa">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {% if tags %}
        <div class="postcard__tags">
          {%- for tag in tags | filterTagList %}
            <span class="tag">{{ tag }}</span>
          {%- endfor %}
        </div>
      {% endif %}
    </div>
  </header>

  {{ content | safe }}
</article>

<nav class="post-back" aria-label="Volver al listado">
  {% if "bitacora" in tags %}
    <a href="/bitacora/" class="post-back__link">&larr; Volver a la bitácora</a>
  {% elif "reflexiones" in tags %}
    <a href="/reflexiones/" class="post-back__link">&larr; Volver a reflexiones</a>
  {% endif %}
</nav>

{%- css %}
.post-header {
  margin-bottom: var(--space-xl);
}
.post-meta {
  font-family: var(--font-mono);
  font-size: var(--fs-1);
  color: var(--color-texto-alt);
  display: flex;
  align-items: center;
  gap: var(--space-m);
  flex-wrap: wrap;
  margin-top: var(--space-s);
}
.post-back {
  margin-top: var(--space-xl);
  padding-top: var(--space-l);
  border-top: 1px solid var(--color-borde);
}
.post-back__link {
  display: inline-flex;
  align-items: center;
  gap: 0.4em;
  font-family: var(--font-mono);
  font-size: var(--fs-1);
  color: var(--color-texto-alt);
  text-decoration: none;
  padding: 0.5em 1em;
  border: 1px solid var(--color-borde);
  border-radius: var(--radius-m);
  transition: color var(--transition-fast),
    border-color var(--transition-fast),
    background-color var(--transition-fast);
}
.post-back__link:hover {
  color: var(--color-acento);
  border-color: var(--color-acento);
  background-color: var(--color-acento-suave);
}
{% endcss %}
