---
layout: layouts/base.njk
---
<article class="prosa">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      <span class="post-meta__sep">&middot;</span>
      <span>{{ content | readingTime }} de lectura</span>
    </div>
    {% if tags %}
      <div class="post-tags">
        {%- for tag in tags | filterTagList %}
          <a href="/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
        {%- endfor %}
      </div>
    {% endif %}
  </header>

  {{ content | safe }}
</article>

{% if "bitacora" in tags %}
  {%- set sectionPosts = collections.bitacora %}
  {%- set sectionUrl = "/bitacora/" %}
  {%- set sectionName = "la bitácora" %}
{% elif "reflexiones" in tags %}
  {%- set sectionPosts = collections.reflexiones %}
  {%- set sectionUrl = "/reflexiones/" %}
  {%- set sectionName = "reflexiones" %}
{% endif %}

{%- set prevPost = null %}
{%- set nextPost = null %}
{%- if sectionPosts %}
  {%- for post in sectionPosts %}
    {%- if post.url == page.url %}
      {%- if loop.index0 > 0 %}
        {%- set prevPost = sectionPosts[loop.index0 - 1] %}
      {%- endif %}
      {%- if loop.index0 < sectionPosts.length - 1 %}
        {%- set nextPost = sectionPosts[loop.index0 + 1] %}
      {%- endif %}
    {%- endif %}
  {%- endfor %}
{%- endif %}

<nav class="post-nav" aria-label="Navegación entre artículos">
  {% if prevPost %}
    <a href="{{ prevPost.url }}" class="post-nav__link post-nav__link--prev">
      <span class="post-nav__label">&larr; Anterior</span>
      <span class="post-nav__title">{{ prevPost.data.title }}</span>
    </a>
  {% else %}
    <span></span>
  {% endif %}
  {% if nextPost %}
    <a href="{{ nextPost.url }}" class="post-nav__link post-nav__link--next">
      <span class="post-nav__label">Siguiente &rarr;</span>
      <span class="post-nav__title">{{ nextPost.data.title }}</span>
    </a>
  {% else %}
    <span></span>
  {% endif %}
</nav>

<nav class="post-back" aria-label="Volver al listado">
  <a href="{{ sectionUrl }}" class="post-back__link">&larr; Volver a {{ sectionName }}</a>
</nav>

{%- css %}
.post-header {
  margin-bottom: var(--space-xl);
}
.post-meta {
  font-family: var(--font-mono);
  font-size: var(--fs-1);
  color: var(--color-texto-alt);
  margin-top: var(--space-s);
  display: flex;
  align-items: center;
  gap: 0.5em;
  flex-wrap: wrap;
}
.post-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: var(--space-xs);
}
.post-nav {
  display: flex;
  justify-content: space-between;
  gap: var(--space-m);
  margin-top: var(--space-xl);
  padding-top: var(--space-l);
  border-top: 1px solid var(--color-borde);
}
.post-nav__link {
  display: flex;
  flex-direction: column;
  gap: 0.25em;
  text-decoration: none;
  padding: var(--space-s) var(--space-m);
  border: 1px solid var(--color-borde-sutil);
  border-radius: var(--radius-m);
  max-width: 48%;
  transition: border-color var(--transition-fast),
    background-color var(--transition-fast);
}
.post-nav__link:hover {
  border-color: var(--color-acento);
  background-color: var(--color-fondo-alt);
}
.post-nav__link--next {
  text-align: right;
  margin-left: auto;
}
.post-nav__label {
  font-family: var(--font-mono);
  font-size: var(--fs-2);
  color: var(--color-texto-alt);
}
.post-nav__title {
  font-size: var(--fs-1);
  font-weight: 600;
  color: var(--color-texto);
}
@media screen and (max-width: 45rem) {
  .post-nav {
    flex-direction: column;
  }
  .post-nav__link {
    max-width: 100%;
  }
}
{% endcss %}
