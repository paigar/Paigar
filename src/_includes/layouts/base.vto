<!DOCTYPE html>
<html lang="{{ metadata.language }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title || metadata.title }}</title>
    <meta name="description" content="{{ description || metadata.description }}">
    <link rel="canonical" href="{{ metadata.url }}{{ url }}">

    <link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
    <meta name="generator" content="Lume">

    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-icon-152x152.png">
    <link rel="apple-touch-icon" sizes="144x144" href="/apple-icon-144x144.png">
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-icon-120x120.png">
    <link rel="apple-touch-icon" sizes="114x114" href="/apple-icon-114x114.png">
    <link rel="apple-touch-icon" sizes="76x76" href="/apple-icon-76x76.png">
    <link rel="apple-touch-icon" sizes="72x72" href="/apple-icon-72x72.png">
    <link rel="apple-touch-icon" sizes="60x60" href="/apple-icon-60x60.png">
    <link rel="apple-touch-icon" sizes="57x57" href="/apple-icon-57x57.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png">

    <script>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.classList.add('js');
      })();
    </script>

    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/tokens.css">
    <link rel="stylesheet" href="/css/theme.css">
    <link rel="stylesheet" href="/fonts/fonts.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/code.css">
    <link rel="stylesheet" href="/css/pages.css">

    <meta property="og:title" content="{{ title || metadata.title }}">
    <meta property="og:description" content="{{ description || metadata.description }}">
    <meta property="og:url" content="{{ metadata.url }}{{ url }}">
    <meta property="og:type" content="website">
    {{ if tags && (tags.includes("bitacora") || tags.includes("reflexiones")) }}
    <meta property="og:image" content="{{ metadata.url }}/og-images/{{ page.src.slug }}.png">
    {{ else }}
    <meta property="og:image" content="{{ metadata.url }}/og-images/default.png">
    {{ /if }}
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title || metadata.title }}">
    <meta name="twitter:description" content="{{ description || metadata.description }}">
    {{ if tags && (tags.includes("bitacora") || tags.includes("reflexiones")) }}
    <meta name="twitter:image" content="{{ metadata.url }}/og-images/{{ page.src.slug }}.png">
    {{ else }}
    <meta name="twitter:image" content="{{ metadata.url }}/og-images/default.png">
    {{ /if }}
  </head>
  <body{{ if bodyClass }} class="{{ bodyClass }}"{{ /if }}>
    <a href="#skip" class="visually-hidden">Saltar al contenido principal</a>

    {{ include "partials/cabecera.vto" }}
    {{ include "partials/theme-toggle.vto" }}
    {{ include "partials/nav-panel.vto" }}

    <main id="skip" class="limites cuerpo">
      {{ content }}
    </main>

    {{ include "partials/pie.vto" }}

    <script src="/js/theme-toggle.js"></script>
    <script src="/js/externallinks.js"></script>
    <script src="/js/reveal.js"></script>
    <script src="/js/nav-mobile.js"></script>

    <link rel="stylesheet" href="/css/cookieconsent.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="/css/cookieconsent.css"></noscript>
    <script defer src="/js/cookieconsent.js"></script>
    <script defer src="/js/cookieconsent-init.js"></script>
  </body>
</html>
