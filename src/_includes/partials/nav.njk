<nav class="nav" aria-label="Navegación principal">
  {%- for item in mainmenu.items %}
    <a href="{{ item.url }}" class="nav__link"{% if page.url == item.url or (item.url != "/" and page.url | startsWith(item.url)) %} aria-current="page"{% endif %}>
      {{ item.text }}
    </a>
  {%- endfor %}
</nav>

{# Hamburguesa para móvil #}
<button class="nav-hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-panel">
  <span class="nav-hamburger__bar"></span>
  <span class="nav-hamburger__bar"></span>
  <span class="nav-hamburger__bar"></span>
</button>
