---json
{
	"permalink": "feed/feed.xml",
	"eleventyExcludeFromCollections": true,
	"metadata": {
		"title": "Paigar",
		"subtitle": "Web personal de Juanjo Marcos — desarrollo web, código y reflexiones.",
		"language": "es",
		"url": "https://www.paigar.es/",
		"author": {
			"name": "Juanjo Marcos",
			"email": "juanjo@paigar.es"
		}
	}
}
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ metadata.language or page.lang }}">
	<title>{{ metadata.title }}</title>
	<subtitle>{{ metadata.subtitle }}</subtitle>
	<link href="{{ metadata.url }}{{ page.url }}" rel="self"/>
	<link href="{{ metadata.url }}"/>
	<updated>{{ collections.bitacora | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
	<id>{{ metadata.url }}</id>
	<author>
		<name>{{ metadata.author.name }}</name>
		<email>{{ metadata.author.email }}</email>
	</author>
	{%- for post in collections.bitacora | reverse | head(20) %}
	{%- set absolutePostUrl = post.url | htmlBaseUrl(metadata.url) %}
	<entry>
		<title>{{ post.data.title }}</title>
		<link href="{{ absolutePostUrl }}"/>
		<updated>{{ post.date | dateToRfc3339 }}</updated>
		<id>{{ absolutePostUrl }}</id>
		<content xml:lang="{{ metadata.language }}" type="html">{{ post.templateContent | htmlToAbsoluteUrls(absolutePostUrl) }}</content>
	</entry>
	{%- endfor %}
</feed>
