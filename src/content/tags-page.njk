---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - bitacora
    - reflexiones
layout: layouts/base.njk
eleventyComputed:
  title: "Tag: {{ tag }}"
  description: "Artículos etiquetados con « {{ tag }} »."
  permalink: "/tags/{{ tag | slugify }}/"
---

<div class="seccion-header reveal ancho">
  <h1 class="seccion-header__title"><span class="seccion-header__marker">//</span> {{ tag }}</h1>
  <p class="seccion-header__description">{{ collections[tag] | length }} artículo{{ "s" if collections[tag] | length != 1 }} con esta etiqueta.</p>
</div>

{%- set posts = collections[tag] | ordenarPorFecha %}
{%- if posts.length > 0 %}
  <div class="posts-grid reveal-stagger ancho">
    {%- for post in posts %}
      {% include "partials/postcard.njk" %}
    {%- endfor %}
  </div>
{%- endif %}

<nav class="post-back ancho" style="margin-top: var(--space-xl);">
  <a href="/tags/" class="post-back__link">&larr; Todos los tags</a>
</nav>
